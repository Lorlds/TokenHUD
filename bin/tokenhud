claude    planned      ~/.claude/ after format verification
aider     planned      local Aider history/analytics after format verification
cursor    research     local Cursor storage after version-specific verification
llamacpp  planned      local logs/metrics with user-configured cost
EOF
  exit 0
fi

if [ "$mode" = "prices-check" ]; then
  prices_check
  exit 0
fi

if [ "$mode" = "models" ]; then
  printf '%-24s %-10s %-8s %-11s %-11s %-11s %-24s %-12s %-6s\n' "model" "api" "visible" "input" "cached" "output" "status" "updated" "stale"
  codex debug models | jq -r '.models[] | [.slug, (.supported_in_api|tostring), (.visibility // "")] | @tsv' \
    | while IFS=$'\t' read -r slug supported visibility; do
        IFS=$'\t' read -r usd_input_rate usd_cached_rate usd_output_rate _credit_input _credit_cached _credit_output pricing_status pricing_updated pricing_stale <<EOF
$(price_table "$slug")
EOF
        printf '%-24s %-10s %-8s %-11s %-11s %-11s %-24s %-12s %-6s\n' \
          "$slug" "$supported" "$visibility" "$usd_input_rate" "$usd_cached_rate" "$usd_output_rate" "$pricing_status" "$pricing_updated" "$pricing_stale"
      done
  exit 0
fi

calc_metered_cost() {
  local input="$1" cached="$2" output="$3" input_rate="$4" cached_rate="$5" output_rate="$6"
  if [ "$input_rate" = "n/a" ] || [ "$cached_rate" = "n/a" ] || [ "$output_rate" = "n/a" ]; then
    printf 'n/a'
    return
  fi
  awk -v input="$input" -v cached="$cached" -v output="$output" \
    -v input_rate="$input_rate" -v cached_rate="$cached_rate" -v output_rate="$output_rate" 'BEGIN {
      if (cached > input) cached = input;
      uncached = input - cached;
      printf "%.6f", ((uncached * input_rate) + (cached * cached_rate) + (output * output_rate)) / 1000000;
    }'
}

money() {
  local value="${1:-n/a}"
  local bare="${2:-0}"
  if [ "$value" = "n/a" ] || ! awk -v n="$value" 'BEGIN { exit !(n ~ /^-?[0-9]+([.][0-9]+)?$/) }'; then
    printf 'n/a'
    return
  fi
  awk -v n="$value" 'BEGIN {
    if (n < 0.01) printf "%.4f", n;
    else if (n < 1) printf "%.3f", n;
    else printf "%.2f", n;
  }' | {
    IFS= read -r formatted
    if [ "$bare" = "1" ]; then
      printf '%s' "$formatted"
    else
      printf '$%s' "$formatted"
    fi
  }
}

credit_fmt() {
  local value="${1:-n/a}"
  if [ "$value" = "n/a" ] || ! awk -v n="$value" 'BEGIN { exit !(n ~ /^-?[0-9]+([.][0-9]+)?$/) }'; then
    printf 'n/a'
    return
  fi
  awk -v n="$value" 'BEGIN {
    if (n < 10) printf "%.2fcr", n;
    else if (n < 100) printf "%.1fcr", n;
    else printf "%.0fcr", n;
  }'
}

git_summary() {
  local dir="$1"
  if ! git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'no-git'
    return
  fi
  local branch changed
  branch="$(git -C "$dir" branch --show-current 2>/dev/null || true)"
  [ -z "$branch" ] && branch="$(git -C "$dir" rev-parse --short HEAD 2>/dev/null || true)"
  changed="$(git -C "$dir" status --short 2>/dev/null | wc -l | tr -d ' ')"
  if [ "${changed:-0}" -gt 0 ]; then
    printf '%s +%s' "$branch" "$changed"
  else
    printf '%s clean' "$branch"
  fi
}

config_model() {
  local file="$1" requested_profile="${2:-}"
  [ -f "$file" ] || return 0
  awk -v requested_profile="$requested_profile" '
    function trim(s) {
      sub(/^[ \t\r\n]+/, "", s)
      sub(/[ \t\r\n]+$/, "", s)
      return s
    }
    function uncomment(s, out, i, c, inq, esc) {
      out = ""; inq = 0; esc = 0
      for (i = 1; i <= length(s); i++) {
        c = substr(s, i, 1)
        if (c == "\"" && esc == 0) inq = !inq
        if (c == "#" && inq == 0) break
        out = out c
        if (c == "\\" && esc == 0) esc = 1
        else esc = 0
      }
      return out
    }
    function value(line) {
      sub(/^[^=]*=/, "", line)
      line = trim(uncomment(line))
      if (line ~ /^".*"$/) {
        sub(/^"/, "", line)
        sub(/"$/, "", line)
      }
      return line
    }
    BEGIN { section = ""; root_model = ""; active_profile = requested_profile }
    /^[ \t]*(#|$)/ { next }
    /^[ \t]*\[/ {
      section = $0
      sub(/^[ \t]*\[/, "", section)
      sub(/\][ \t]*$/, "", section)
      next
    }
    section == "" && /^[ \t]*profile[ \t]*=/ {
      if (active_profile == "") active_profile = value($0)
      next
    }
    section == "" && /^[ \t]*model[ \t]*=/ {
      root_model = value($0)
      next
    }
    (section == ("profile." active_profile) || section == ("profiles." active_profile)) && /^[ \t]*model[ \t]*=/ {
      profile_model = value($0)
      next
    }
    END {
      if (profile_model != "") print profile_model
      else if (root_model != "") print root_model
    }
  ' "$file"
}

session="${session_arg:-}"
[ -z "$session" ] && session="$(latest_session "$cwd_arg")"

if [ -z "$session" ] || [ ! -f "$session" ]; then
  echo "tokenhud: no Codex session file found"
  exit 1
fi

token_filter='
  fromjson?
  |
  select(
    .type == "event_msg"
    and .payload.type == "token_count"
    and (.payload.info.total_token_usage? != null)
  )
'

event=""
if [ "$tail_lines" -gt 0 ]; then
  event="$(tail -n "$tail_lines" "$session" | jq -Rrc "$token_filter" 2>/dev/null | tail -n 1 || true)"
fi
[ -z "$event" ] && event="$(jq -Rrc "$token_filter" "$session" 2>/dev/null | tail -n 1 || true)"

if [ -z "$event" ]; then
  echo "tokenhud: no Codex token_count event found"
  exit 1
fi

meta="$(session_meta_payload "$session")"

IFS=$'\t' read -r session_id session_cwd cli_version provider session_model <<EOF
$(printf '%s\n' "$meta" | jq -r '[
  (.id // "n/a"),
  (.cwd // "n/a"),
  (.cli_version // "n/a"),
  (.model_provider // "n/a"),
  (.model // .model_slug // .model_id // .model_name // .config.model // "n/a")
] | @tsv')
EOF

IFS=$'\t' read -r _event_ts last_input last_cached last_output last_reasoning last_total total_input total_cached total_output total_reasoning total_total context_window primary_used primary_reset primary_window secondary_used secondary_reset secondary_window plan_type <<EOF
$(printf '%s\n' "$event" | jq -r '
  .payload.info as $i
  | .payload.rate_limits as $r
  | [
      (.timestamp // "n/a"),
      ($i.last_token_usage.input_tokens // 0),
      ($i.last_token_usage.cached_input_tokens // 0),
      ($i.last_token_usage.output_tokens // 0),
      ($i.last_token_usage.reasoning_output_tokens // 0),
      ($i.last_token_usage.total_tokens // 0),
      ($i.total_token_usage.input_tokens // 0),
      ($i.total_token_usage.cached_input_tokens // 0),
      ($i.total_token_usage.output_tokens // 0),
      ($i.total_token_usage.reasoning_output_tokens // 0),
      ($i.total_token_usage.total_tokens // 0),
      ($i.model_context_window // 0),
      ($r.primary.used_percent // "n/a"),
      ($r.primary.resets_at // "n/a"),
      ($r.primary.window_minutes // "n/a"),
      ($r.secondary.used_percent // "n/a"),
      ($r.secondary.resets_at // "n/a"),
      ($r.secondary.window_minutes // "n/a"),
      ($r.plan_type // "n/a")
    ] | @tsv
')
EOF

config_model_value="$(config_model "$codex_home/config.toml" "${CODEX_PROFILE:-}")"
if [ -n "${session_model:-}" ] && [ "$session_model" != "n/a" ] && [ "$session_model" != "null" ]; then
  model="$session_model"
else
  model="$config_model_value"
fi
[ -z "$model" ] && model="codex"
model="$(env_or_compat TOKENHUD_MODEL CODEXHUD_MODEL "$model")"
IFS=$'\t' read -r usd_input_rate usd_cached_rate usd_output_rate credit_input_rate credit_cached_rate credit_output_rate pricing_status pricing_updated pricing_stale <<EOF
$(price_table "$model")
EOF

display_cwd="${cwd_arg:-$session_cwd}"
if [ -z "$display_cwd" ] || [ "$display_cwd" = "null" ]; then
  display_cwd="$PWD"
fi
short_cwd="${display_cwd/#$HOME/~}"
git_info="$(git_summary "$display_cwd")"
session_short="${session_id:0:8}"

ctx_pct="$(awk -v used="${last_total:-0}" -v win="${context_window:-0}" 'BEGIN {
  if (used !~ /^-?[0-9]+([.][0-9]+)?$/) used = 0;
  if (win ~ /^-?[0-9]+([.][0-9]+)?$/ && win > 0) printf "%.1f", (used / win) * 100;
  else printf "0";
}')"
bar="$(progress_bar "$ctx_pct" 10)"

primary_reset_rel="$(rel_time "$primary_reset")"
secondary_reset_rel="$(rel_time "$secondary_reset")"
age="$(elapsed_since_iso "$(printf '%s\n' "$meta" | jq -r '.timestamp // empty' 2>/dev/null || true)")"
last_usd="$(calc_metered_cost "$last_input" "$last_cached" "$last_output" "$usd_input_rate" "$usd_cached_rate" "$usd_output_rate")"
total_usd="$(calc_metered_cost "$total_input" "$total_cached" "$total_output" "$usd_input_rate" "$usd_cached_rate" "$usd_output_rate")"
last_credits="$(calc_metered_cost "$last_input" "$last_cached" "$last_output" "$credit_input_rate" "$credit_cached_rate" "$credit_output_rate")"
total_credits="$(calc_metered_cost "$total_input" "$total_cached" "$total_output" "$credit_input_rate" "$credit_cached_rate" "$credit_output_rate")"

plain_money() {
  money "$1" 1
}

risk_label() {
  local pct="${1:-0}"
  awk -v p="$pct" 'BEGIN {
    if (p >= 95) print "compact-now";
    else if (p >= 85) print "compact-soon";
    else if (p >= 75) print "watch";
    else print "steady";
  }'
}

pricing_flag() {
  local status="${pricing_status:-unknown}" stale="${pricing_stale:-false}"
  if [ "$status" = "configured" ] && [ "$stale" != "true" ]; then
    return
  fi
  if [ "$stale" = "true" ]; then
    case "$status" in
      configured) printf ' price:stale' ;;
      provisional-*) printf ' price:stale/provisional' ;;
      *) printf ' price:stale/%s' "$status" ;;
    esac
    return
  fi
  case "$status" in
    provisional-*) printf ' price:provisional' ;;
    unknown-model) printf ' price:unknown' ;;
    *) printf ' price:%s' "$status" ;;
  esac
}

case "$mode" in
  json)
    printf '%s\n' "$event" | jq \
      --arg session_file "$session" \
      --arg adapter "codex" \
      --arg session_id "$session_id" \
      --arg session_short "$session_short" \
      --arg cli_version "$cli_version" \
      --arg provider "$provider" \
      --arg model "$model" \
      --arg cwd "$display_cwd" \
      --arg git "$git_info" \
      --arg context_percentage "$ctx_pct" \
      --arg pricing_status "$pricing_status" \
      --arg pricing_updated "$pricing_updated" \
      --arg pricing_stale "$pricing_stale" \
      --arg pricing_file "$price_config_file" \
      --arg usd_input_rate "$usd_input_rate" \
      --arg usd_cached_rate "$usd_cached_rate" \
      --arg usd_output_rate "$usd_output_rate" \
      --arg credit_input_rate "$credit_input_rate" \
      --arg credit_cached_rate "$credit_cached_rate" \
      --arg credit_output_rate "$credit_output_rate" \
      --arg last_usd "$last_usd" \
      --arg total_usd "$total_usd" \
      --arg last_credits "$last_credits" \
      --arg total_credits "$total_credits" \
      --arg age "$age" \
      '{
        product: "TokenHUD",
        adapter: $adapter,
        session_file: $session_file,
        timestamp: .timestamp,
        session: {
          id: $session_id,
          short_id: $session_short,
          age: $age,
          cli_version: $cli_version,
          provider: $provider
        },
        model: $model,
        cwd: $cwd,
        git: $git,
        context: {
          used_percentage: ($context_percentage | tonumber),
          window: .payload.info.model_context_window
        },
        tokens: {
          last: .payload.info.last_token_usage,
          total: .payload.info.total_token_usage
        },
        rate_limits: .payload.rate_limits,
        pricing: {
          status: $pricing_status,
          last_updated: $pricing_updated,
          stale: ($pricing_stale == "true"),
          file: $pricing_file,
          usd_per_1m_tokens: {
            input: $usd_input_rate,
            cached_input: $usd_cached_rate,
            output: $usd_output_rate
          },
          codex_credits_per_1m_tokens: {
            input: $credit_input_rate,
            cached_input: $credit_cached_rate,
            output: $credit_output_rate
          }
        },
        cost: {
          last_usd: $last_usd,
          session_usd: $total_usd,
          last_credits: $last_credits,
          session_credits: $total_credits
        }
      }'
    ;;
  full)
    echo "TokenHUD"
    echo "adapter: codex model: $model provider: $provider version: $cli_version session: $session_short age: $age"
    echo "cwd: $short_cwd"
    echo "git: $git_info"
    echo "context: $bar $(percent "$ctx_pct") last=$(short_num "$last_total") window=$(short_num "$context_window")"
    echo "last tokens: input=$(short_num "$last_input") cached=$(short_num "$last_cached") output=$(short_num "$last_output") reasoning=$(short_num "$last_reasoning") total=$(short_num "$last_total")"
    echo "session tokens: input=$(short_num "$total_input") cached=$(short_num "$total_cached") output=$(short_num "$total_output") reasoning=$(short_num "$total_reasoning") total=$(short_num "$total_total")"
    echo "cost estimate: last=$(money "$last_usd") / $(credit_fmt "$last_credits") session=$(money "$total_usd") / $(credit_fmt "$total_credits")"
    echo "rates per 1M: input=$usd_input_rate cached=$usd_cached_rate output=$usd_output_rate USD; input=$credit_input_rate cached=$credit_cached_rate output=$credit_output_rate credits; status=$pricing_status stale=$pricing_stale updated=$pricing_updated file=$price_config_file"
    echo "rate limits: ${primary_window}m=${primary_used}% reset=$primary_reset_rel ${secondary_window}m=${secondary_used}% reset=$secondary_reset_rel plan=$plan_type"
    ;;
  compact|tmux)
    style="$(env_or_compat TOKENHUD_STYLE CODEXHUD_STYLE balanced)"
    if [ "$style" = "ascii" ]; then
      bar="$(progress_bar "$ctx_pct" 10 1)"
    fi
    risk="$(risk_label "$ctx_pct")"
    case "$style" in
      minimal)
        printf 'TH %s %s %s %s%s' \
          "$(percent "$ctx_pct")" \
          "$(money "$total_usd")" \
          "$(credit_fmt "$total_credits")" \
          "$git_info" \
          "$(pricing_flag)"
        ;;
      ledger)
        printf 'TH codex last %s/%s | session %s/%s | in %s out %s%s' \
          "$(money "$last_usd")" \
          "$(credit_fmt "$last_credits")" \
          "$(money "$total_usd")" \
          "$(credit_fmt "$total_credits")" \
          "$(short_num "$total_input")" \
          "$(short_num "$total_output")" \
          "$(pricing_flag)"
        ;;
      risk)
        printf 'TH %s %s %s  %s  lim %s/%s%%  %s%s' \
          "$bar" \
          "$(percent "$ctx_pct")" \
          "$risk" \
          "$(money "$total_usd")" \
          "$primary_used" \
          "$secondary_used" \
          "$git_info" \
          "$(pricing_flag)"
        ;;
      executive)
        printf 'TokenHUD | adapter codex | ctx %s | session %s / %s | limits %s/%s%%%s' \
          "$(percent "$ctx_pct")" \
          "$(money "$total_usd")" \
          "$(credit_fmt "$total_credits")" \
          "$primary_used" \
          "$secondary_used" \
          "$(pricing_flag)"
        ;;
      focus)
        printf 'TH %s %s %s%s' \
          "$(percent "$ctx_pct")" \
          "$risk" \
          "$(money "$total_usd")" \
          "$(pricing_flag)"
        ;;
      ascii|balanced|*)
        printf 'TH codex:%s %s %s  $ %s/%s  cr %s/%s  lim %s/%s%%  %s%s' \
          "$model" \
          "$bar" \
          "$(percent "$ctx_pct")" \
          "$(plain_money "$last_usd")" \
          "$(plain_money "$total_usd")" \
          "$(credit_fmt "$last_credits")" \
          "$(credit_fmt "$total_credits")" \
          "$primary_used" \
          "$secondary_used" \
          "$git_info" \
          "$(pricing_flag)"
        ;;
    esac
    ;;
esac
